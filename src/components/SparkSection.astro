---
import ProjectCard from './ProjectCard.astro';

const cards = [
  {
    title: 'Business Website',
    outcome: 'A booking page, service listing, or landing page for your business — live and yours.',
    icon: '🏪',
  },
  {
    title: 'Game',
    outcome: 'A playable game you built yourself, from idea to something you can share.',
    icon: '🎮',
  },
  {
    title: 'Raspberry Pi Project',
    outcome: 'A custom script, home dashboard, or automation running on real hardware.',
    icon: '🖥️',
  },
  {
    title: 'Online Store',
    outcome: 'A storefront for your product or craft — ready to take orders.',
    icon: '🛒',
  },
];
---

<section class="py-16 px-4 sm:px-6 border-b border-gray-100">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl sm:text-3xl font-bold mb-4">What will you build?</h2>
    <p class="text-gray-600 mb-10 max-w-lg">Pick the one that sounds like you. Greg will handle the rest.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {cards.map((card) => (
        <ProjectCard title={card.title} outcome={card.outcome} icon={card.icon} />
      ))}
    </div>
  </div>
</section>
