---
import CTAButton from './CTAButton.astro';
---

<section class="py-20 px-4 sm:px-6 border-b border-gray-100">
  <div class="max-w-5xl mx-auto">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6 max-w-3xl">
      Build something real.<br />This Saturday.
    </h1>
    <p class="text-lg sm:text-xl text-gray-600 mb-10 max-w-xl">
      In-person AI and web-building sessions in Langford, BC. Show up with an idea. Leave with something built.
    </p>
    <CTAButton href="/contact" label="Let's Talk" />
  </div>
</section>
