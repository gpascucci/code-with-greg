---
import CTAButton from './CTAButton.astro';

const pathname = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/sessions', label: 'Sessions' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
    <a href="/" class="font-bold text-lg tracking-tight text-black no-underline">
      Kode With Greg
    </a>

    <nav class="hidden sm:flex items-center gap-8">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'text-sm font-medium no-underline transition-colors',
            (pathname === href || (href !== '/' && pathname.startsWith(href))) ? 'text-black font-semibold' : 'text-gray-500 hover:text-black',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <CTAButton href="/contact" label="Let's Talk" />

      <details class="sm:hidden relative">
        <summary class="list-none cursor-pointer p-2 -mr-2" aria-label="Open navigation menu">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
            <rect y="4" width="22" height="2" fill="currentColor"/>
            <rect y="10" width="22" height="2" fill="currentColor"/>
            <rect y="16" width="22" height="2" fill="currentColor"/>
          </svg>
        </summary>
        <nav class="absolute right-0 top-full mt-1 w-44 bg-white border border-gray-200 shadow-md flex flex-col py-2">
          {links.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                'px-5 py-3 text-sm font-medium no-underline transition-colors',
                (pathname === href || (href !== '/' && pathname.startsWith(href))) ? 'text-black font-semibold' : 'text-gray-600 hover:text-black',
              ]}
            >
              {label}
            </a>
          ))}
        </nav>
      </details>
    </div>
  </div>
</header>
