---
interface Props {
  name: string;
  description: string;
  audience: string;
}

const { name, description, audience } = Astro.props;
---

<div class="border border-gray-200 p-8 flex flex-col gap-4 hover:border-black transition-colors">
  <h3 class="text-xl font-bold">{name}</h3>
  <p class="text-gray-600 leading-relaxed">{description}</p>
  <p class="text-sm text-gray-400 mt-auto pt-4 border-t border-gray-100">
    <span class="font-medium text-gray-700">Good for:</span> {audience}
  </p>
</div>
