---
interface Props {
  title: string;
  outcome: string;
  icon?: string;
}

const { title, outcome, icon = '◆' } = Astro.props;
---

<div class="border border-gray-200 p-6 flex flex-col gap-3 hover:border-black transition-colors">
  <span class="text-2xl" aria-hidden="true">{icon}</span>
  <h3 class="font-bold text-lg">{title}</h3>
  <p class="text-gray-600 text-sm leading-relaxed">{outcome}</p>
</div>
