---
import CTAButton from './CTAButton.astro';

interface Props {
  heading: string;
  cta: string;
  href?: string;
}

const { heading, cta, href = '/contact' } = Astro.props;
---

<section class="bg-black text-white py-16 px-4 sm:px-6 text-center">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-2xl sm:text-3xl font-bold mb-8">{heading}</h2>
    <CTAButton href={href} label={cta} variant="secondary" />
  </div>
</section>
